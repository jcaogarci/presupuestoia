# ============================================================
# PresupuestoIA — Variables de entorno
# Copia este archivo como .env y rellena los valores
# En Vercel: añádelos en Settings > Environment Variables
# ============================================================

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXX

# Supabase
SUPABASE_URL=https://XXXXXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyXXXXXX   # Service role key (solo para backend)
SUPABASE_ANON_KEY=eyXXXXXX      # Anon key (para frontend)

# Stripe
STRIPE_SECRET_KEY=sk_live_XXXXXXXX        # sk_test_XXX para pruebas
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXX
STRIPE_PRICE_PRO=price_XXXXXXXX           # ID del precio mensual Pro (€29/mes)
STRIPE_PRICE_EMPRESA=price_XXXXXXXX       # ID del precio mensual Empresa (€79/mes)

# App
NEXT_PUBLIC_APP_URL=https://presupuestoia.com
